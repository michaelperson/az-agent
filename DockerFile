# Utilise la dernière version disponible de Node.js sur Debian Bookworm
FROM node:current-bookworm

# Évite les prompts interactifs lors de l'installation des paquets
ENV DEBIAN_FRONTEND=noninteractive
# Forcer sonar-scanner à utiliser le Java système et désactiver le téléchargement automatique du JRE
ENV SONAR_SCANNER_OPTS="-Djava.home=/usr/lib/jvm/default-java"
ENV SONAR_SCANNER_JAVA_EXE="/usr/lib/jvm/default-java/bin/java"
ENV SONAR_SCANNER_SKIP_JRE_PROVISIONING="true"
RUN echo "APT::Get::Assume-Yes \"true\";" > /etc/apt/apt.conf.d/90assumeyes

# Installation des dépendances requises par l'agent Azure DevOps et d'outils basiques (git, zip, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    jq \
    git \
    iputils-ping \
    libcurl4 \
    libicu-dev \
    libunwind8 \
    netcat-openbsd \
    zip \
    unzip \
    apt-transport-https \
    software-properties-common \
 && rm -rf /var/lib/apt/lists/*

# Installation du Docker CLI officiel (version récente compatible avec le daemon hôte)
RUN curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
 && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian bookworm stable" \
    > /etc/apt/sources.list.d/docker.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends docker-ce-cli \
 && rm -rf /var/lib/apt/lists/*

# Installation de Java (requis par sonar-scanner)
RUN apt-get update && apt-get install -y --no-install-recommends \
    default-jre-headless \
 && rm -rf /var/lib/apt/lists/*

# Installation du Sonar Scanner officiel v6 (compatible SonarQube v26+)
RUN curl -sSL https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-6.2.1.4610-linux-x64.zip \
      -o /tmp/sonar-scanner.zip \
 && unzip /tmp/sonar-scanner.zip -d /opt \
 && mv /opt/sonar-scanner-6.2.1.4610-linux-x64 /opt/sonar-scanner \
 && rm -rf /opt/sonar-scanner/jre \
 && chmod -R +x /opt/sonar-scanner/bin/ \
 && ln -s /opt/sonar-scanner/bin/sonar-scanner /usr/local/bin/sonar-scanner \
 && rm /tmp/sonar-scanner.zip

# Configurer sonar-scanner pour utiliser le Java système
RUN echo "sonar.scanner.skipJreProvisioning=true" >> /opt/sonar-scanner/conf/sonar-scanner.properties \
 && echo "sonar.scanner.javaExePath=/usr/bin/java" >> /opt/sonar-scanner/conf/sonar-scanner.properties

# Corriger jspawnhelper cassé sur WSL2 — remplacer par un wrapper shell
RUN JSPAWN=$(find /usr/lib/jvm -name "jspawnhelper" 2>/dev/null | head -1) \
 && if [ -n "$JSPAWN" ]; then \
      mv "$JSPAWN" "${JSPAWN}.bak" \
      && printf '#!/bin/sh\nexec "$@"\n' > "$JSPAWN" \
      && chmod +x "$JSPAWN"; \
    fi

# JAVA_HOME pointant vers le Java système
ENV JAVA_HOME="/usr/lib/jvm/default-java"
ENV PATH="$JAVA_HOME/bin:$PATH"

# Installation de ESLint globalement
RUN npm install -g eslint@8

# Création du répertoire de travail pour l'agent
WORKDIR /azp

# Copie du script de démarrage
COPY start.sh .
RUN chmod +x start.sh

# Définition du script de démarrage comme point d'entrée
CMD ["./start.sh"]